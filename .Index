<!-- ====== TAB: HISTORIAL ====== -->
<div id="tab-historial" class="tab-content">
  <div class="card">
    <div class="card-title">📁 Historial de Liquidaciones</div>
    <div class="hist-filters no-print">
      <select id="f-asesora" onchange="filtrarHistorial()">
        <option value="">👥 Todas las asesoras</option>
      </select>
      <input type="month" id="f-periodo" onchange="filtrarHistorial()" placeholder="Período">
      <button class="btn btn-ghost btn-sm" onclick="limpiarFiltros()">✕ Limpiar</button>
    </div>
    <div id="lista-historial"><div class="empty-state"><span class="icon">📋</span>Cargando historial…</div></div>
  </div>
</div>

<!-- MODAL IMPRESIÓN -->
<div id="modal-print" class="modal-overlay">
  <div class="modal-box">
    <div id="print-content"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="cerrarModal()">Cerrar</button>
      <button class="btn btn-primary" onclick="window.print()">🖨️ Imprimir / PDF</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ============================================================
// SUPABASE
// ============================================================
const SURL = 'https://sertvddcfboldonhcrqk.supabase.co';
const SKEY = 'sb_publishable_EdFcEFH73CRMnPutElWfgg_SPRC1K1b';
const H = () => ({ apikey:SKEY, Authorization:`Bearer ${SKEY}`, 'Content-Type':'application/json' });

const db = {
  async get(t, q='') {
    const r = await fetch(`${SURL}/rest/v1/${t}?${q}&order=created_at.desc`, { headers:H() });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  },
  async upsert(t, data) {
    const r = await fetch(`${SURL}/rest/v1/${t}`, {
      method:'POST', headers:{...H(), Prefer:'resolution=merge-duplicates,return=representation'},
      body:JSON.stringify(data)
    });
    if (!r.ok) throw new Error(await r.text());
    return r.json();
  },
  async del(t, id) {
    const r = await fetch(`${SURL}/rest/v1/${t}?id=eq.${id}`, { method:'DELETE', headers:H() });
    if (!r.ok) throw new Error(await r.text());
  }
};

// ============================================================
// UTILS
// ============================================================
const fmt = n => Math.round(n).toLocaleString('es-CL',{style:'currency',currency:'CLP',minimumFractionDigits:0});
const pct = (n,p) => Math.round(n*p/100);
const setv = (id,v) => { const e=document.getElementById(id); if(e&&v!=null) e.value=v; };
const MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const nomMes = yyyymm => { if(!yyyymm) return ''; const[y,m]=yyyymm.split('-'); return MESES[+m-1]+' '+y; };
const COLORES = ['','color2','color3','color4',''];
function toast(msg, tipo='ok') {
  const el = document.getElementById('toast');
  el.textContent = msg; el.className = `toast show t${tipo}`;
  setTimeout(()=>el.className='toast', 3200);
}
function fmtRut(inp) {
  let v = inp.value.replace(/[^0-9kK]/g,'');
  if(v.length>1) v = v.slice(0,-1).replace(/\B(?=(\d{3})+(?!\d))/g,'.')+'-'+v.slice(-1);
  inp.value = v;
}

// ============================================================
// ESTADO
// ============================================================
let asesoras = [];       // todas las asesoras
let asesoraActiva = null; // asesora seleccionada
let ausencias = [];      // para calculadora días
let _histRows = [];      // historial completo

// ============================================================
// INIT
// ============================================================
async function init() {
  const st = document.getElementById('db-status');
  setv('periodo', new Date().toISOString().slice(0,7));
  setv('d-periodo', new Date().toISOString().slice(0,7));
  setv('v-inicio', new Date().toISOString().slice(0,10));
  calcular(); calcDias();
  try {
    await db.get('asesoras','limit=1');
    st.textContent = '● Supabase conectado'; st.className = 'db-status db-ok';
    await cargarAsesoras();
    await cargarHistorial();
  } catch(e) {
    st.textContent = '● Modo local'; st.className = 'db-status db-err';
    cargarAsesorasLocal();
    cargarHistLocal();
  }
}

// ============================================================
// GESTIÓN ASESORAS
// ============================================================
async function cargarAsesoras() {
  try {
    const rows = await db.get('asesoras','limit=100');
    asesoras = rows || [];
  } catch(e) { cargarAsesorasLocal(); return; }
  localStorage.setItem('asesoras_cache', JSON.stringify(asesoras));
  renderListaAsesoras();
  actualizarSelectorAsesora();
  // Auto-seleccionar la última activa
  const ultimaId = localStorage.getItem('asesora_activa_id');
  if (ultimaId) {
    const a = asesoras.find(x => x.id == ultimaId);
    if (a) setAsesoraActiva(a);
  } else if (asesoras.length === 1) {
    setAsesoraActiva(asesoras[0]);
  }
}

function cargarAsesorasLocal() {
  asesoras = JSON.parse(localStorage.getItem('asesoras_cache')||'[]');
  renderListaAsesoras();
  actualizarSelectorAsesora();
  const ultimaId = localStorage.getItem('asesora_activa_id');
  if (ultimaId) {
    const a = asesoras.find(x => x.id == ultimaId);
    if (a) setAsesoraActiva(a);
  }
}

function renderListaAsesoras() {
  const el = document.getElementById('lista-asesoras');
  if (!asesoras.length) { el.innerHTML = '<div class="empty-state"><span class="icon">👤</span>No hay asesoras registradas. Agrega la primera.</div>'; return; }
  el.innerHTML = asesoras.map((a,i) => `
    <div class="asesor-card ${asesoraActiva?.id === a.id ? 'selected' : ''}" id="card-asesor-${a.id}">
      <div class="asesor-avatar ${COLORES[i%4]}">${a.nombre[0].toUpperCase()}</div>
      <div class="asesor-info">
        <strong>${a.nombre} ${asesoraActiva?.id === a.id ? '<span class="badge badge-sel">ACTIVA</span>' : ''}</strong>
        <p>RUT: ${a.rut||'—'} · AFP ${a.afp_nombre||'—'} · Sueldo: ${fmt(a.sueldo_base||539000)}</p>
        <p>Ingreso: ${a.fecha_ingreso ? new Date(a.fecha_ingreso+'T12:00').toLocaleDateString('es-CL') : '—'} · ${a.tipo_contrato||'indefinido'}</p>
      </div>
      <div class="asesor-actions">
        <button class="btn btn-primary btn-sm" onclick="seleccionarYLiquidar('${a.id}')">📄 Liquidar</button>
        <button class="btn btn-ghost btn-sm" onclick="editarAsesora('${a.id}')">✏️</button>
        <button class="btn-danger-sm" onclick="eliminarAsesora('${a.id}')">✕</button>
      </div>
    </div>`).join('');
}

function actualizarSelectorAsesora() {
  const sel = document.getElementById('selector-asesora');
  const valActual = sel.value;
  sel.innerHTML = '<option value="">— Selecciona una asesora —</option>';
  asesoras.forEach(a => {
    const opt = document.createElement('option');
    opt.value = a.id; opt.textContent = a.nombre;
    sel.appendChild(opt);
  });
  if (asesoraActiva) sel.value = asesoraActiva.id;
  // Actualizar filtro historial
  const fSel = document.getElementById('f-asesora');
  fSel.innerHTML = '<option value="">👥 Todas las asesoras</option>';
  asesoras.forEach(a => {
    const opt = document.createElement('option');
    opt.value = a.nombre; opt.textContent = a.nombre;
    fSel.appendChild(opt);
  });
}

function cambiarAsesora(id) {
  if (!id) { asesoraActiva = null; actualizarUIAsesora(); return; }
  const a = asesoras.find(x => x.id == id);
  if (a) setAsesoraActiva(a);
}

function setAsesoraActiva(a) {
  asesoraActiva = a;
  localStorage.setItem('asesora_activa_id', a.id);
  document.getElementById('selector-asesora').value = a.id;
  actualizarUIAsesora();
  renderListaAsesoras();
}

function actualizarUIAsesora() {
  const warnEl = document.getElementById('liq-warn-sin-asesora');
  const miniEl = document.getElementById('liq-perfil-mini');
  if (!asesoraActiva) {
    warnEl.style.display = 'block'; miniEl.style.display = 'none'; return;
  }
  warnEl.style.display = 'none';
  miniEl.style.display = 'flex';
  const ing = asesoraActiva.fecha_ingreso ? new Date(asesoraActiva.fecha_ingreso+'T12:00').toLocaleDateString('es-CL') : '—';
  miniEl.innerHTML = `<div class="perfil-mini">
    <div class="asesor-avatar" style="width:48px;height:48px;font-size:1.4rem">${asesoraActiva.nombre[0].toUpperCase()}</div>
    <div>
      <h3>${asesoraActiva.nombre} <span class="badge">Activa</span></h3>
      <p>RUT: ${asesoraActiva.rut||'—'} · AFP ${asesoraActiva.afp_nombre||'—'} · Ingreso: ${ing}</p>
    </div>
  </div>`;
  sincLiquidacion();
}

function sincLiquidacion() {
  if (!asesoraActiva) return;
  const a = asesoraActiva;
  setv('sueldo', a.sueldo_base||539000);
  setv('movilizacion', a.movilizacion||0);
  setv('colacion', a.colacion||0);
  setv('contrato', a.tipo_contrato||'indefinido');
  const afpSel = document.getElementById('afp');
  for(let i=0;i<afpSel.options.length;i++){
    if(afpSel.options[i].dataset.nombre===a.afp_nombre){afpSel.selectedIndex=i;break;}
  }
  // Vacaciones auto-fill
  if(a.fecha_ingreso) setv('v-ingreso', a.fecha_ingreso);
  setv('v-sueldo', a.sueldo_base||539000);
  setv('v-anios', a.anios_totales||0);
  calcular();
}

function seleccionarYLiquidar(id) {
  const a = asesoras.find(x => x.id == id);
  if (!a) return;
  setAsesoraActiva(a);
  showTab('liquidacion', document.querySelectorAll('.tab-btn')[1]);
}

// ===== FORMULARIO ASESORA =====
function nuevaAsesora() {
  document.getElementById('a-id').value = '';
  document.getElementById('form-asesora-titulo').textContent = '➕ Nueva Asesora';
  ['a-nombre','a-rut','a-telefono','a-email','a-antiguedad','a-notas'].forEach(id=>setv(id,''));
  ['a-nacimiento','a-ingreso'].forEach(id=>setv(id,''));
  setv('a-sueldo',539000); setv('a-movilizacion',78000); setv('a-colacion',78000);
  setv('a-contrato','indefinido'); setv('a-modalidad','puertas_afuera');
  setv('a-anios-totales',0);
  document.getElementById('form-asesora-card').style.display = 'block';
  showTab('asesoras', document.querySelectorAll('.tab-btn')[0]);
  document.getElementById('form-asesora-card').scrollIntoView({behavior:'smooth'});
}

function editarAsesora(id) {
  const a = asesoras.find(x=>x.id==id); if(!a) return;
  setv('a-id', a.id);
  document.getElementById('form-asesora-titulo').textContent = '✏️ Editar Asesora';
  setv('a-nombre',a.nombre); setv('a-rut',a.rut); setv('a-telefono',a.telefono);
  setv('a-email',a.email); setv('a-nacimiento',a.nacimiento);
  setv('a-ingreso',a.fecha_ingreso); setv('a-contrato',a.tipo_contrato);
  setv('a-modalidad',a.modalidad); setv('a-sueldo',a.sueldo_base);
  setv('a-movilizacion',a.movilizacion); setv('a-colacion',a.colacion);
  setv('a-anios-totales',a.anios_totales); setv('a-notas',a.notas);
  const afpSel = document.getElementById('a-afp');
  for(let i=0;i<afpSel.options.length;i++){
    if(afpSel.options[i].dataset.nombre===a.afp_nombre){afpSel.selectedIndex=i;break;}
  }
  if(a.fecha_ingreso) calcAnt();
  document.getElementById('form-asesora-card').style.display = 'block';
  document.getElementById('form-asesora-card').scrollIntoView({behavior:'smooth'});
}

function cancelarFormAsesora() { document.getElementById('form-asesora-card').style.display = 'none'; }

async function guardarAsesora() {
  const nombre = document.getElementById('a-nombre').value.trim();
  if (!nombre) { toast('⚠️ Ingresa el nombre','err'); return; }
  const afpSel = document.getElementById('a-afp');
  const data = {
    nombre, rut:document.getElementById('a-rut').value,
    nacimiento:document.getElementById('a-nacimiento').value||null,
    telefono:document.getElementById('a-telefono').value,
    email:document.getElementById('a-email').value,
    fecha_ingreso:document.getElementById('a-ingreso').value||null,
    tipo_contrato:document.getElementById('a-contrato').value,
    modalidad:document.getElementById('a-modalidad').value,
    sueldo_base:+document.getElementById('a-sueldo').value||539000,
    movilizacion:+document.getElementById('a-movilizacion').value||0,
    colacion:+document.getElementById('a-colacion').value||0,
    afp_nombre:afpSel.options[afpSel.selectedIndex].dataset.nombre,
    afp_tasa:+afpSel.value,
    anios_totales:+document.getElementById('a-anios-totales').value||0,
    notas:document.getElementById('a-notas').value
  };
  const editId = document.getElementById('a-id').value;
  if (editId) data.id = editId;
  try {
    const res = await db.upsert('asesoras', data);
    const saved = Array.isArray(res)?res[0]:res;
    const idx = asesoras.findIndex(x=>x.id==saved.id);
    if(idx>=0) asesoras[idx]=saved; else asesoras.unshift(saved);
    if(asesoraActiva?.id==saved.id) asesoraActiva=saved;
    localStorage.setItem('asesoras_cache',JSON.stringify(asesoras));
    toast('✅ Asesora guardada en Supabase');
  } catch(e) {
    if(!editId) data.id = 'local_'+Date.now();
    const idx = asesoras.findIndex(x=>x.id==data.id);
    if(idx>=0) asesoras[idx]=data; else asesoras.unshift(data);
    localStorage.setItem('asesoras_cache',JSON.stringify(asesoras));
    toast('💾 Guardado localmente');
  }
  renderListaAsesoras();
  actualizarSelectorAsesora();
  cancelarFormAsesora();
}

async function eliminarAsesora(id) {
  const a = asesoras.find(x=>x.id==id);
  if(!confirm(`¿Eliminar a ${a?.nombre}? También se eliminarán sus liquidaciones.`)) return;
  try { await db.del('asesoras',id); } catch(e) {}
  asesoras = asesoras.filter(x=>x.id!=id);
  localStorage.setItem('asesoras_cache',JSON.stringify(asesoras));
  if(asesoraActiva?.id==id) { asesoraActiva=null; actualizarUIAsesora(); }
  renderListaAsesoras(); actualizarSelectorAsesora();
  toast('🗑️ Asesora eliminada');
}

function calcAnt() {
  const fi = document.getElementById('a-ingreso').value;
  if(!fi) return;
  const tot = Math.floor((new Date()-new Date(fi+'T12:00'))/(1000*60*60*24*365.25)*12);
  const y=Math.floor(tot/12), m=tot%12;
  setv('a-antiguedad', y>0?`${y} año${y>1?'s':''} ${m>0?`y ${m} mes${m>1?'es':''}`:''}` : `${tot} mes${tot!==1?'es':''}`);
}

// ============================================================
// CALCULADORA DÍAS
// ============================================================
function toggleIngrParcial() {
  document.getElementById('d-ingreso-fecha-grp').style.display =
    document.getElementById('d-ingreso-parcial').value==='si'?'block':'none';
}

function calcDias() {
  const periodo=document.getElementById('d-periodo').value; if(!periodo) return;
  const jornada=document.getElementById('d-jornada').value;
  const ingParcial=document.getElementById('d-ingreso-parcial').value;
  const ingFecha=document.getElementById('d-ingreso-fecha').value;
  const[y,m]=periodo.split('-').map(Number);
  const diasMes=jornada==='30'?30:new Date(y,m,0).getDate();
  let base=diasMes, detalles=[];
  if(ingParcial==='si'&&ingFecha){
    const fi=new Date(ingFecha+'T12:00');
    if(fi.getFullYear()===y&&fi.getMonth()+1===m){
      base=diasMes-fi.getDate()+1;
      detalles.push(`• Ingresó el día ${fi.getDate()}: ${base} días desde el ingreso`);
    }
  } else { detalles.push(`• Mes ${jornada==='30'?'estándar (30)':'real'}: ${base} días base`); }
  let aus=0, ext=0;
  ausencias.forEach(a=>{
    const ini=new Date(a.desde+'T12:00'),fin=new Date(a.hasta+'T12:00');
    const d=Math.round((fin-ini)/86400000)+1;
    if(a.tipo==='feriado'){ext+=d; detalles.push(`• Feriado trabajado "${a.desc}": +${d} día${d>1?'s':''}`)}
    else{aus+=d; detalles.push(`• ${a.desc} (${lTipo(a.tipo)}): −${d} día${d>1?'s':''}`)}
  });
  const res=Math.max(0,base-aus+ext);
  document.getElementById('d-resultado').textContent=res;
  document.getElementById('d-base').textContent=base;
  document.getElementById('d-ausentes').textContent=aus;
  document.getElementById('d-extra').textContent=ext;
  document.getElementById('d-detalle').innerHTML=detalles.length
    ?detalles.join('<br>')+'<br><br><strong style="color:var(--dark)">→ Total a pagar: '+res+' días</strong>':'—';
}

function addAusencia() {
  const tipo=document.getElementById('d-tipo').value;
  const desc=document.getElementById('d-desc').value||lTipo(tipo);
  const desde=document.getElementById('d-desde').value;
  const hasta=document.getElementById('d-hasta').value||desde;
  if(!desde){toast('Selecciona la fecha de inicio','err');return;}
  ausencias.push({tipo,desc,desde,hasta,id:Date.now()});
  renderAus(); calcDias();
  document.getElementById('d-desc').value='';
}

function delAus(id){ausencias=ausencias.filter(a=>a.id!==id);renderAus();calcDias();}

function renderAus(){
  const el=document.getElementById('lista-ausencias');
  const card=document.getElementById('card-ausencias');
  if(!ausencias.length){card.style.display='none';return;}
  card.style.display='block';
  el.innerHTML=ausencias.map(a=>{
    const ini=new Date(a.desde+'T12:00'),fin=new Date(a.hasta+'T12:00');
    const d=Math.round((fin-ini)/86400000)+1;
    return`<div class="ausencia-item">
      <div class="ai"><strong>${a.desc}</strong><span class="tipo-badge tipo-${a.tipo}">${lTipo(a.tipo)}</span>
      <span>${ini.toLocaleDateString('es-CL')} → ${fin.toLocaleDateString('es-CL')}</span></div>
      <div class="ad">${a.tipo==='feriado'?'+':'−'}${d}d</div>
      <button onclick="delAus(${a.id})" style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:1rem;padding:0 4px">✕</button>
    </div>`;
  }).join('');
}

const lTipo=t=>({injustificada:'Injustificada',justificada:'Justificada',licencia:'Licencia Médica',vacaciones:'Vacaciones',feriado:'Feriado (+)',permiso:'Permiso s/Goce'})[t]||t;

function usarDias(){
  const d=document.getElementById('d-resultado').textContent;
  const p=document.getElementById('d-periodo').value;
  setv('dias',d); if(p) setv('periodo',p);
  calcular(); showTab('liquidacion',document.querySelectorAll('.tab-btn')[1]);
  toast(`✅ ${d} días aplicados a la liquidación`);
}

function escenario(tipo){
  const p=document.getElementById('d-periodo').value||new Date().toISOString().slice(0,7);
  setv('d-periodo',p); ausencias=[];
  document.getElementById('d-ingreso-parcial').value='no';
  document.getElementById('d-ingreso-fecha-grp').style.display='none';
  const[y,m]=p.split('-');
  if(tipo==='ingreso15'){document.getElementById('d-ingreso-parcial').value='si';document.getElementById('d-ingreso-fecha-grp').style.display='block';setv('d-ingreso-fecha',`${y}-${m}-15`);}
  else if(tipo==='ingreso20'){document.getElementById('d-ingreso-parcial').value='si';document.getElementById('d-ingreso-fecha-grp').style.display='block';setv('d-ingreso-fecha',`${y}-${m}-20`);}
  else if(tipo==='aus1'){ausencias.push({tipo:'injustificada',desc:'Inasistencia injustificada',desde:`${y}-${m}-10`,hasta:`${y}-${m}-10`,id:Date.now()});}
  else if(tipo==='licencia5'){ausencias.push({tipo:'licencia',desc:'Licencia médica',desde:`${y}-${m}-05`,hasta:`${y}-${m}-09`,id:Date.now()});}
  else if(tipo==='licencia7'){ausencias.push({tipo:'licencia',desc:'Licencia médica',desde:`${y}-${m}-05`,hasta:`${y}-${m}-11`,id:Date.now()});}
  else if(tipo==='vacaciones5'){ausencias.push({tipo:'vacaciones',desc:'Vacaciones',desde:`${y}-${m}-10`,hasta:`${y}-${m}-14`,id:Date.now()});}
  renderAus(); calcDias();
}

// ============================================================
// CALCULAR LIQUIDACIÓN
// ============================================================
function calcular() {
  const nombre=asesoraActiva?.nombre||'NOMBRE COMPLETO';
  const rut=asesoraActiva?.rut||'—';
  const periodo=document.getElementById('periodo').value;
  const dias=+document.getElementById('dias').value||30;
  const afpSel=document.getElementById('afp');
  const afpTasa=+afpSel.value;
  const afpNombre=afpSel.options[afpSel.selectedIndex].dataset.nombre;
  const sueldoBase=+document.getElementById('sueldo').value||539000;
  const movilizacion=+document.getElementById('movilizacion').value||0;
  const colacion=+document.getElementById('colacion').value||0;
  const horasExtra=+document.getElementById('horasExtra').value||0;
  const bono=+document.getElementById('bono').value||0;
  const descAdicional=+document.getElementById('descAdicional').value||0;
  const sueldo=dias<30?Math.round(sueldoBase*dias/30):sueldoBase;
  const totalHaberes=sueldo+movilizacion+colacion+horasExtra+bono;
  const rentaImponible=Math.max(sueldo+horasExtra+bono,539000);
  const descAfp=pct(rentaImponible,afpTasa);
  const descSalud=pct(rentaImponible,7);
  const totalDescuentos=descAfp+descSalud+descAdicional;
  const liquido=totalHaberes-totalDescuentos;
  const costoSIS=pct(rentaImponible,1.54);
  const costoSS=pct(rentaImponible,0.9);
  const costoAcc=pct(rentaImponible,0.93);
  const costoAfpAd=pct(rentaImponible,0.1);
  const costoCes=pct(rentaImponible,3.0);
  const totalEmp=totalHaberes+costoSIS+costoSS+costoAcc+costoAfpAd+costoCes;
  const d={nombre,rut,periodo,dias,afpNombre,afpTasa,sueldoBase,sueldo,movilizacion,colacion,horasExtra,bono,descAdicional,totalHaberes,rentaImponible,descAfp,descSalud,totalDescuentos,liquido,costoSIS,costoSS,costoAcc,costoAfpAd,costoCes,totalEmp};
  renderLiq(d); return d;
}

// El HTML de la liquidación "limpia" (sin employer costs) para imprimir
function htmlLiqLimpia(d) {
  return `<div class="liq-preview">
    <div class="liq-header">
      <h2>LIQUIDACIÓN DE SUELDO</h2>
      <p>Trabajadora de Casa Particular · ${nomMes(d.periodo)}</p>
    </div>
    <div class="liq-body">
      <div class="liq-worker">
        <div class="liq-worker-info">
          <h3>${d.nombre}</h3>
          <p>RUT: ${d.rut}</p>
          <p>AFP ${d.afpNombre} · FONASA · Casa Particular</p>
        </div>
        <div class="liq-worker-info" style="text-align:right">
          <p>Período: <strong>${nomMes(d.periodo)}</strong></p>
          <p>Días trabajados: <strong>${d.dias}</strong></p>
          <p>Renta Imponible: <strong>${fmt(d.rentaImponible)}</strong></p>
        </div>
      </div>
      <div class="liq-section">
        <div class="liq-section-title">✅ Haberes</div>
        <div class="liq-row"><span>Sueldo Base${d.dias<30?` (${d.dias}/30 días)`:''}</span><span class="pos">${fmt(d.sueldo)}</span></div>
        ${d.movilizacion>0?`<div class="liq-row"><span>Movilización (no imponible)</span><span class="pos">${fmt(d.movilizacion)}</span></div>`:''}
        ${d.colacion>0?`<div class="liq-row"><span>Colación (no imponible)</span><span class="pos">${fmt(d.colacion)}</span></div>`:''}
        ${d.horasExtra>0?`<div class="liq-row"><span>Horas Extra</span><span class="pos">${fmt(d.horasExtra)}</span></div>`:''}
        ${d.bono>0?`<div class="liq-row"><span>Bono / Gratificación</span><span class="pos">${fmt(d.bono)}</span></div>`:''}
      </div>
      <div class="liq-section">
        <div class="liq-section-title">❌ Descuentos Legales</div>
        <div class="liq-row"><span>AFP ${d.afpNombre} (${d.afpTasa}%)</span><span class="neg">−${fmt(d.descAfp)}</span></div>
        <div class="liq-row"><span>FONASA (7%)</span><span class="neg">−${fmt(d.descSalud)}</span></div>
        ${d.descAdicional>0?`<div class="liq-row"><span>Descuento Adicional</span><span class="neg">−${fmt(d.descAdicional)}</span></div>`:''}
      </div>
      <div class="liq-totals">
        <div class="liq-total-row"><span>Total Haberes</span><span>${fmt(d.totalHaberes)}</span></div>
        <div class="liq-total-row"><span>Total Descuentos</span><span>−${fmt(d.totalDescuentos)}</span></div>
        <div class="liq-total-row final"><span>💰 LÍQUIDO A PAGAR</span><span>${fmt(d.liquido)}</span></div>
      </div>
    </div>
    <div class="liq-footer">
      <div><div class="firma-line">${d.nombre}<br>TRABAJADOR(A) · RUT ${d.rut}</div></div>
      <div><div class="firma-line">EMPLEADOR(A)<br>&nbsp;</div></div>
    </div>
  </div>`;
}

function renderLiq(d) {
  document.getElementById('resultado-liquidacion').innerHTML =
    htmlLiqLimpia(d) +
    `<div class="employer-costs no-print">
      <h4>📋 Costo Total Empleador (informativo — no aparece al imprimir)</h4>
      <div class="cost-row"><span>SIS (1,54%)</span><span>${fmt(d.costoSIS)}</span></div>
      <div class="cost-row"><span>Seg. Social Expectativa Vida (0,9%)</span><span>${fmt(d.costoSS)}</span></div>
      <div class="cost-row"><span>Accidente del Trabajo (0,93%)</span><span>${fmt(d.costoAcc)}</span></div>
      <div class="cost-row"><span>Aporte Adicional AFP (0,1%)</span><span>${fmt(d.costoAfpAd)}</span></div>
      <div class="cost-row"><span>Seg. Cesantía Casa Particular (3%)</span><span>${fmt(d.costoCes)}</span></div>
      <div class="cost-row"><span>Total Costo Empleador</span><span>${fmt(d.totalEmp)}</span></div>
    </div>`;
  window._ultimaLiq = d;
}

// ============================================================
// GUARDAR LIQUIDACIÓN
// ============================================================
async function guardarLiquidacion() {
  const d = calcular();
  if (!asesoraActiva) { toast('⚠️ Selecciona una asesora primero','err'); return; }
  const entrada = {
    asesora_id:asesoraActiva.id||null,
    nombre:d.nombre, rut:d.rut, periodo:d.periodo, dias:d.dias,
    afp_nombre:d.afpNombre, afp_tasa:d.afpTasa,
    sueldo_base:d.sueldoBase, movilizacion:d.movilizacion, colacion:d.colacion,
    horas_extra:d.horasExtra, bono:d.bono,
    total_haberes:d.totalHaberes, renta_imponible:d.rentaImponible,
    desc_afp:d.descAfp, desc_salud:d.descSalud,
    total_descuentos:d.totalDescuentos, liquido:d.liquido,
    costo_sis:d.costoSIS, costo_seg_social:d.costoSS,
    costo_accidente:d.costoAcc, costo_afp_adicional:d.costoAfpAd,
    costo_cesantia:d.costoCes, total_costo_empleador:d.totalEmp
  };
  try {
    await db.upsert('liquidaciones',entrada);
    toast('✅ Liquidación guardada en Supabase');
    await cargarHistorial();
  } catch(e) {
    const loc=JSON.parse(localStorage.getItem('hist_liq')||'[]');
    loc.unshift({...entrada,id:'loc_'+Date.now(),created_at:new Date().toISOString()});
    localStorage.setItem('hist_liq',JSON.stringify(loc));
    toast('💾 Guardado localmente'); cargarHistLocal();
  }
}

// ============================================================
// HISTORIAL
// ============================================================
async function cargarHistorial() {
  try {
    const rows=await db.get('liquidaciones','limit=100');
    _histRows=rows||[];
    localStorage.setItem('hist_liq',JSON.stringify(_histRows));
  } catch(e) { cargarHistLocal(); return; }
  renderHistorial(_histRows);
}

function cargarHistLocal() {
  _histRows=JSON.parse(localStorage.getItem('hist_liq')||'[]');
  renderHistorial(_histRows);
}

function filtrarHistorial() {
  const fNombre=document.getElementById('f-asesora').value.toLowerCase();
  const fPeriodo=document.getElementById('f-periodo').value;
  const filtrado=_histRows.filter(h=>{
    const matchN=!fNombre||h.nombre?.toLowerCase().includes(fNombre);
    const matchP=!fPeriodo||h.periodo===fPeriodo;
    return matchN&&matchP;
  });
  renderHistorial(filtrado,true);
}

function limpiarFiltros(){
  setv('f-asesora',''); setv('f-periodo','');
  renderHistorial(_histRows);
}

function renderHistorial(rows, filtrado=false) {
  const el=document.getElementById('lista-historial');
  if(!rows?.length){
    el.innerHTML=`<div class="empty-state"><span class="icon">📋</span>${filtrado?'Sin resultados para ese filtro.':'No hay liquidaciones guardadas aún.'}</div>`;
    return;
  }
  el.innerHTML=rows.map((h,i)=>`
    <div class="history-item" onclick="verLiqHist(${i},'${rows===_histRows?'all':'filtered'}',${_histRows.indexOf(h)})">
      <div>
        <div class="history-month">${nomMes(h.periodo)} <span style="font-size:0.75rem;color:var(--muted);font-weight:400">· ${h.nombre}</span></div>
        <div style="font-size:0.75rem;color:var(--muted)">AFP ${h.afp_nombre} · R.I. ${fmt(h.renta_imponible)} · ${h.dias} días</div>
      </div>
      <div style="display:flex;align-items:center;gap:10px;text-align:right">
        <div><div class="history-net">${fmt(h.liquido)}</div><div style="font-size:0.7rem;color:var(--muted)">Líquido</div></div>
        ${h.id?`<button class="btn-danger-sm" onclick="event.stopPropagation();eliminarLiq('${h.id}')">✕</button>`:''}
      </div>
    </div>`).join('');
}

function verLiqHist(i,src,origIdx) {
  const h=_histRows[origIdx>=0?origIdx:i]; if(!h) return;
  const d={nombre:h.nombre,rut:h.rut,periodo:h.periodo,dias:h.dias,
    afpNombre:h.afp_nombre,afpTasa:h.afp_tasa,sueldoBase:h.sueldo_base,sueldo:h.sueldo_base,
    movilizacion:h.movilizacion,colacion:h.colacion,horasExtra:h.horas_extra,bono:h.bono,descAdicional:0,
    totalHaberes:h.total_haberes,rentaImponible:h.renta_imponible,descAfp:h.desc_afp,descSalud:h.desc_salud,
    totalDescuentos:h.total_descuentos,liquido:h.liquido,costoSIS:h.costo_sis,costoSS:h.costo_seg_social,
    costoAcc:h.costo_accidente,costoAfpAd:h.costo_afp_adicional,costoCes:h.costo_cesantia,totalEmp:h.total_costo_empleador};
  // Mostrar en modal solo la liquidación limpia
  document.getElementById('print-content').innerHTML = htmlLiqLimpia(d);
  document.getElementById('modal-print').style.display='block';
}

async function eliminarLiq(id){
  if(!confirm('¿Eliminar esta liquidación?')) return;
  try{await db.del('liquidaciones',id);}catch(e){}
  _histRows=_histRows.filter(x=>x.id!=id);
  localStorage.setItem('hist_liq',JSON.stringify(_histRows));
  renderHistorial(_histRows); toast('🗑️ Liquidación eliminada');
}

// ============================================================
// IMPRIMIR — solo muestra la liquidación limpia
// ============================================================
function imprimirLiq() {
  const d = calcular();
  document.getElementById('print-content').innerHTML = htmlLiqLimpia(d);
  document.getElementById('modal-print').style.display='block';
}
function cerrarModal(){document.getElementById('modal-print').style.display='none';}

// ============================================================
// VACACIONES
// ============================================================
function calcVac(){
  const ing=document.getElementById('v-ingreso').value;
  const ini=document.getElementById('v-inicio').value;
  const sueldo=+document.getElementById('v-sueldo').value||539000;
  const anios=+document.getElementById('v-anios').value||0;
  const el=document.getElementById('v-resultado');
  if(!ing||!ini){el.style.display='none';return;}
  el.style.display='block';
  const dif=(new Date(ini+'T12:00')-new Date(ing+'T12:00'))/(1000*60*60*24*365.25);
  if(dif<1){
    el.innerHTML=`<div style="font-size:1.2rem;font-family:'Playfair Display',serif;color:var(--accent);text-align:center">⚠️ Sin derecho aún</div>
    <div style="font-size:0.81rem;color:var(--muted);text-align:center;margin-top:6px">No completa 1 año. Tiempo actual: <strong>${(dif*12).toFixed(1)} meses</strong></div>`;
    return;
  }
  let dias=15,prog=0;
  if(anios>=10){prog=Math.floor((anios-10)/3);dias+=prog;}
  const pago=Math.round(sueldo/30*dias);
  el.innerHTML=`<div style="font-size:1.4rem;font-family:'Playfair Display',serif;color:var(--accent);text-align:center">${dias} días hábiles · ${fmt(pago)}</div>
  <div style="font-size:0.81rem;color:var(--muted);text-align:center;margin-top:6px">
    Años con empleador: <strong>${dif.toFixed(1)}</strong> · Años totales: <strong>${anios}</strong><br>
    Días base: 15${prog>0?` + ${prog} días progresivos`:''} · Pago diario: ${fmt(sueldo/30)}<br>
    <strong>Total a pagar: ${fmt(pago)}</strong>
  </div>`;
}

// ============================================================
// TABS
// ============================================================
function showTab(tab,btn){
  document.querySelectorAll('.tab-content').forEach(e=>e.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(e=>e.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  if(btn&&btn.classList) btn.classList.add('active');
  else{
    const tabs=['asesoras','liquidacion','dias','vacaciones','indicadores','historial'];
    const idx=tabs.indexOf(tab);
    const btns=document.querySelectorAll('.tab-btn');
    if(idx>=0&&btns[idx]) btns[idx].classList.add('active');
  }
}

// ============================================================
// START
// ============================================================
init();
</script>
</body>
</html>
