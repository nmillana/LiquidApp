      <tr><td><strong>Habitat</strong></td><td>11,27%</td><td>0,1%</td><td>11,37%</td></tr>
      <tr><td><strong>PlanVital</strong></td><td>11,16%</td><td>0,1%</td><td>11,26%</td></tr>
      <tr><td><strong>Provida</strong></td><td>11,45%</td><td>0,1%</td><td>11,55%</td></tr>
      <tr><td><strong>Modelo</strong></td><td>10,58%</td><td>0,1%</td><td>10,68%</td></tr>
