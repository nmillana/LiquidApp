      <tr><td>SIS (Seguro Invalidez y Sobrevivencia)</td><td>1,54%</td></tr>
      <tr><td>Seguro Social (Expectativa de Vida)</td><td>0,9%</td></tr>
      <tr><td>Accidente del Trabajo</td><td>0,93%</td></tr>
      <tr><td>Aporte Adicional AFP</td><td>0,1%</td></tr>
      <tr><td>Seguro de Cesantía (Casa Particular — solo empleador)</td><td>3,0%</td></tr>
